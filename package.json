{
  "name": "testdino-mcp",
  "version": "1.0.9",
  "mcpName": "io.github.testdino-hq/testdino-mcp",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "testdino-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/testdino-hq/testdino-mcp"
  },
  "description": "A MCP server for TestDino.",
  "homepage": "https://docs.testdino.com/testdino-mcp/overview/",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "tsx dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cursor",
    "ai"
  ],
  "author": "TestDino",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ]
}
